---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PostCard from '../components/PostCard.astro';
import AnimatedHero from '../components/AnimatedHero.tsx';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const featuredNews = sortedNews.slice(0, 3);
---

<Layout title="Bloom Village HOA - Home">
  <Navbar currentPage="home" />
  
  <div class="space-y-16 py-8">
    <!-- Hero Section -->
    <AnimatedHero client:load />

    <!-- Subdivisions -->
    <section class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-slate-900 mb-8">Our 5 Subdivisions</h2>
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        {['Rose Gardens', 'Tulip Hill', 'Lavender Lane', 'Sunflower Square', 'Daisy Dale'].map((sub) => (
          <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm text-center">
            <div class="w-12 h-12 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-3">
              <i class="fas fa-home text-emerald-600"></i>
            </div>
            <h4 class="font-bold text-slate-800 text-sm">{sub}</h4>
            <p class="text-[10px] uppercase text-slate-400 tracking-widest mt-1">Active Community</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Featured News -->
    <section class="max-w-7xl mx-auto px-4">
      <div class="flex justify-between items-end mb-8">
        <div>
          <h2 class="text-3xl font-bold text-slate-900">Latest News</h2>
          <p class="text-slate-500 mt-2">Stay updated with the latest from Bloom Village</p>
        </div>
        <a 
          href="/news"
          class="text-emerald-600 font-bold hover:text-emerald-800 flex items-center transition-colors"
        >
          View All <i class="fas fa-chevron-right ml-2 text-xs"></i>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredNews.map((post) => (
          <PostCard 
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
            category={post.data.category}
            subdivision={post.data.subdivision}
            imageUrl={post.data.imageUrl}
            slug={`/news/${post.slug}`}
          />
        ))}
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="bg-slate-900 dark:bg-slate-800 text-white py-16 mt-20 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center mb-6">
          <div class="bg-emerald-600 p-2 rounded-lg mr-3">
            <i class="fas fa-seedling text-white"></i>
          </div>
          <span class="text-2xl font-bold">Bloom Village HOA</span>
        </div>
        <p class="text-slate-400 max-w-sm mb-6">
          Maintaining the beauty and harmony of our community through proactive management and resident engagement across all 5 subdivisions.
        </p>
      </div>
      
      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Subdivisions</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="#" class="hover:text-white transition-colors">Rose Gardens</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Tulip Hill</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Lavender Lane</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Sunflower Square</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Daisy Dale</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Quick Links</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/news" class="hover:text-white transition-colors">News</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">Board</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 mt-16 pt-8 border-t border-slate-800 text-center text-slate-500 text-xs">
      <p>© 2024 Bloom Village Home Owners Association. All rights reserved.</p>
    </div>
  </footer>
</Layout>
