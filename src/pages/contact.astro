---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.tsx';
---

<Layout title="Bloom Village HOA - Contact Us">
  <Navbar currentPage="contact" />

  <div class="py-8 space-y-16">
    <!-- Header -->
    <section class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6">Contact Us</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Have questions, suggestions, or need assistance? We're here to help. Reach out to the Bloom Village HOA board or submit a maintenance request.
      </p>
    </section>

    <!-- Contact Info & Form -->
    <section class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Contact Information -->
        <div class="lg:col-span-1 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Get in Touch</h2>

            <div class="space-y-6">
              <!-- Email contact - General inquiries link that opens email client -->
              <div class="flex items-start">
                <div class="bg-emerald-100 dark:bg-emerald-900 p-3 rounded-lg mr-4">
                  <i className="fas fa-envelope text-emerald-600 dark:text-emerald-400"></i>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Email</h3>
                  <p class="text-slate-600 dark:text-slate-400 text-sm mb-2">For general inquiries and board communication</p>
                  <a href="mailto:board@bloomvillage.org" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 font-medium">
                    board@bloomvillage.org
                  </a>
                </div>
              </div>

              <!-- Phone contact - Emergency maintenance number that initiates phone call -->
              <div class="flex items-start">
                <div class="bg-emerald-100 dark:bg-emerald-900 p-3 rounded-lg mr-4">
                  <i className="fas fa-phone text-emerald-600 dark:text-emerald-400"></i>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Phone</h3>
                  <p class="text-slate-600 dark:text-slate-400 text-sm mb-2">Emergency maintenance only (24/7)</p>
                  <a href="tel:+15551234567" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 font-medium">
                    (555) 123-4567
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <div class="bg-emerald-100 dark:bg-emerald-900 p-3 rounded-lg mr-4">
                  <i className="fas fa-map-marker-alt text-emerald-600 dark:text-emerald-400"></i>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Address</h3>
                  <p class="text-slate-600 dark:text-slate-400 text-sm">
                    Bloom Village HOA<br />
                    123 Community Drive<br />
                    Springfield, ST 12345
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-emerald-50 dark:bg-slate-800 p-6 rounded-2xl">
            <h3 class="font-bold text-slate-900 dark:text-white mb-3">Response Time</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">
              We typically respond to inquiries within 24-48 hours during business days.
            </p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-slate-600 dark:text-slate-400">General inquiries:</span>
                <span class="font-medium text-slate-900 dark:text-white">24 hours</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-600 dark:text-slate-400">Maintenance requests:</span>
                <span class="font-medium text-slate-900 dark:text-white">48 hours</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-600 dark:text-slate-400">Emergencies:</span>
                <span class="font-medium text-red-600 dark:text-red-400">Immediate</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form - Interactive form that residents can fill out to send messages to the HOA -->
        <div class="lg:col-span-2">
          <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-sm border border-slate-100 dark:border-slate-700">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Send us a Message</h2>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section (Placeholder) -->
    <section class="max-w-7xl mx-auto px-4">
      <div class="bg-slate-100 dark:bg-slate-700 rounded-2xl p-8 text-center">
        <i class="fas fa-map-marked-alt text-4xl text-slate-400 dark:text-slate-500 mb-4"></i>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Find Us</h3>
        <p class="text-slate-600 dark:text-slate-400">
          Interactive map would be embedded here showing Bloom Village location and boundaries.
        </p>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="bg-slate-900 dark:bg-slate-800 text-white py-16 mt-20 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center mb-6">
          <div class="bg-emerald-600 p-2 rounded-lg mr-3">
            <i class="fas fa-seedling text-white"></i>
          </div>
          <span class="text-2xl font-bold">Bloom Village HOA</span>
        </div>
        <p class="text-slate-400 max-w-sm mb-6">
          Maintaining the beauty and harmony of our community through proactive management and resident engagement across all 5 subdivisions.
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Subdivisions</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="#" class="hover:text-white transition-colors">Rose Gardens</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Tulip Hill</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Lavender Lane</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Sunflower Square</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Daisy Dale</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Quick Links</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/news" class="hover:text-white transition-colors">News</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">Board</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 mt-16 pt-8 border-t border-slate-800 text-center text-slate-500 text-xs">
      <p>© 2024 Bloom Village Home Owners Association. All rights reserved.</p>
    </div>
  </footer>
</Layout>