---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import StoryblokClient from 'storyblok-js-client';

// Check if Storyblok is properly configured
const token = import.meta.env.STORYBLOK_TOKEN;
const isStoryblokConfigured = token && token !== 'placeholder_token';

// Initialize Storyblok client only if configured
let storyblokClient = null;
if (isStoryblokConfigured) {
  storyblokClient = new StoryblokClient({
    accessToken: token,
    cache: {
      clear: 'auto',
      type: 'memory'
    }
  });
}

// Fetch announcements from Storyblok
let announcements = [];
if (storyblokClient) {
  try {
    const response = await storyblokClient.get('cdn/stories', {
      starts_with: 'announcements/',
      version: 'published',
      sort_by: 'first_published_at:desc'
    });

    announcements = response.data.stories.map(story => ({
      _id: story.id,
      title: story.name,
      content: story.content?.body || '',
      date: story.first_published_at,
      priority: story.content?.priority || 'normal',
      contactInfo: story.content?.contactInfo || ''
    })) || [];
  } catch (error) {
    // Handle case where Storyblok is not set up yet
    console.log('Storyblok not configured yet, showing empty announcements');
    announcements = [];
  }
} else {
  // Storyblok not configured, show empty state
  announcements = [];
}
---

<Layout title="Bloom Village HOA - Announcements">
  <Navbar currentPage="announcements" />

  <div class="py-8 space-y-16">
    <!-- Header -->
    <section class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6">Announcements</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Important updates and announcements from the Bloom Village community, managed through our content management system.
      </p>
    </section>

    <!-- Announcements from Sanity -->
    <section class="max-w-4xl mx-auto px-4">
      {announcements.length > 0 ? (
        <div class="space-y-8">
          {announcements.map((announcement) => (
            <article class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-sm border border-slate-100 dark:border-slate-700">
              <div class="flex items-start justify-between mb-4">
                <div class="flex-1">
                  <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
                    {announcement.title}
                  </h2>
                  {announcement.date && (
                    <p class="text-slate-500 dark:text-slate-400 text-sm">
                      {new Date(announcement.date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </p>
                  )}
                </div>
                {announcement.priority === 'urgent' && (
                  <span class="bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 px-3 py-1 rounded-full text-sm font-medium">
                    Urgent
                  </span>
                )}
              </div>

              <div class="prose dark:prose-invert max-w-none">
                {announcement.content}
              </div>

              {announcement.contactInfo && (
                <div class="mt-6 p-4 bg-emerald-50 dark:bg-emerald-900/20 rounded-lg">
                  <h3 class="font-semibold text-emerald-800 dark:text-emerald-200 mb-2">Contact Information</h3>
                  <p class="text-emerald-700 dark:text-emerald-300 text-sm">
                    {announcement.contactInfo}
                  </p>
                </div>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <i class="fas fa-bullhorn text-5xl text-slate-300 dark:text-slate-600 mb-4"></i>
          <h3 class="text-xl font-bold text-slate-700 dark:text-slate-300">No announcements at this time</h3>
          <p class="text-slate-500 dark:text-slate-400 mt-2">Check back soon for updates!</p>
        </div>
      )}
    </section>

    <!-- Content Management Info - Explains how board members can manage announcements -->
    <section class="bg-slate-50 dark:bg-slate-800 py-16">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Content Management</h2>
        <p class="text-slate-600 dark:text-slate-400 mb-8 max-w-2xl mx-auto">
          This page demonstrates dynamic content management with Sanity. Board members can now easily add, edit, and publish announcements without technical knowledge.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
          <!-- Visual Editor feature - Allows easy content creation -->
          <div class="bg-white dark:bg-slate-700 p-6 rounded-lg">
            <i class="fas fa-edit text-2xl text-emerald-600 dark:text-emerald-400 mb-3"></i>
            <h3 class="font-bold text-slate-900 dark:text-white mb-2">Visual Editor</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">Easy-to-use visual editor for creating content</p>
          </div>
          <!-- Real-time Updates feature - Changes appear immediately -->
          <div class="bg-white dark:bg-slate-700 p-6 rounded-lg">
            <i class="fas fa-clock text-2xl text-emerald-600 dark:text-emerald-400 mb-3"></i>
            <h3 class="font-bold text-slate-900 dark:text-white mb-2">Real-time Updates</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">Changes appear instantly on the website</p>
          </div>
          <!-- Team Collaboration feature - Multiple people can work together -->
          <div class="bg-white dark:bg-slate-700 p-6 rounded-lg">
            <i class="fas fa-users text-2xl text-emerald-600 dark:text-emerald-400 mb-3"></i>
            <h3 class="font-bold text-slate-900 dark:text-white mb-2">Team Collaboration</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">Multiple users can edit and review content</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="bg-slate-900 dark:bg-slate-800 text-white py-16 mt-20 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center mb-6">
          <div class="bg-emerald-600 p-2 rounded-lg mr-3">
            <i class="fas fa-seedling text-white"></i>
          </div>
          <span class="text-2xl font-bold">Bloom Village HOA</span>
        </div>
        <p class="text-slate-400 max-w-sm mb-6">
          Maintaining the beauty and harmony of our community through proactive management and resident engagement across all 5 subdivisions.
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Subdivisions</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="#" class="hover:text-white transition-colors">Rose Gardens</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Tulip Hill</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Lavender Lane</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Sunflower Square</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Daisy Dale</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-6 text-emerald-400 uppercase tracking-widest text-xs">Quick Links</h4>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/news" class="hover:text-white transition-colors">News</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">Board</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/announcements" class="hover:text-white transition-colors">Announcements</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 mt-16 pt-8 border-t border-slate-800 text-center text-slate-500 text-xs">
      <p>© 2024 Bloom Village Home Owners Association. All rights reserved.</p>
    </div>
  </footer>
</Layout>